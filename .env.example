# ============================================================
# Bot Framework - Azure Bot Registration
# ============================================================
APP_ID=your-bot-app-id-here
APP_PASSWORD=your-bot-app-password-here

# ============================================================
# Proveedor LLM (elegir UNO)
# Opciones: openai | azure_openai | gemini | claude | perplexity
# ============================================================
LLM_PROVIDER=gemini

# ============================================================
# OpenAI (usar cuando LLM_PROVIDER=openai)
# ============================================================
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o

# ============================================================
# Azure OpenAI (usar cuando LLM_PROVIDER=azure_openai)
# ============================================================
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_API_KEY=your-azure-openai-api-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# ============================================================
# Google Gemini (usar cuando LLM_PROVIDER=gemini)
# ============================================================
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# ============================================================
# Anthropic Claude (usar cuando LLM_PROVIDER=claude)
# ============================================================
CLAUDE_API_KEY=sk-ant-your-claude-api-key-here
CLAUDE_MODEL=claude-sonnet-4-20250514

# ============================================================
# Perplexity (usar cuando LLM_PROVIDER=perplexity)
# ============================================================
PERPLEXITY_API_KEY=pplx-your-perplexity-api-key-here
PERPLEXITY_MODEL=sonar-pro

# ============================================================
# Power BI Service Principal Authentication
# ============================================================
PBI_TENANT_ID=your-azure-tenant-id-here
PBI_CLIENT_ID=your-service-principal-client-id-here
PBI_CLIENT_SECRET=your-service-principal-client-secret-here
